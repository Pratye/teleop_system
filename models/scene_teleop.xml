<mujoco model="teleop_five_dof_scene">
  <compiler angle="radian" eulerseq="xyz" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <asset>
    <texture name="texgrid" builtin="checker" width="512" height="512" rgb1="0.93 0.93 0.93" rgb2="0.85 0.85 0.85"/>
    <material name="floor_mat" texture="texgrid" texrepeat="6 6"/>
    <material name="workspace_mat" rgba="0.2 0.7 1.0 0.08"/>
  </asset>

  <!--
    Contact groups:
      contype / conaffinity bitmask 1  = default (everything collides)
      The robot base_plate is excluded from colliding with the tabletop because
      the root body sits slightly inside the table for mounting purposes.
      All arm links retain default collision so they naturally bounce off the table.
  -->
  <contact>
    <exclude body1="robot_root" body2="table"/>
  </contact>

  <worldbody>
    <light directional="true" diffuse="0.84 0.84 0.84" pos="1 3 8" dir="-1 -3 -8"/>
    <geom name="floor" type="plane" size="4 4 0.01" rgba="1 1 1 1" material="floor_mat"
          contype="1" conaffinity="1"/>

    <!-- ── Table ── -->
    <!-- Table centre in world: x=0.45 y=0 z=0.785
         Tabletop is ±0.025 in Z → top surface at world-z = 0.810 -->
    <body name="table" pos="0.45 0 0.785">
      <geom name="tabletop" type="box" pos="0 0 0" size="0.45 0.35 0.025"
            rgba="0.73 0.57 0.34 1" contype="1" conaffinity="1"/>
      <geom name="table_leg1" type="cylinder" pos=" 0.30  0.22 -0.40" size="0.03 0.40"
            rgba="0.50 0.50 0.50 1"/>
      <geom name="table_leg2" type="cylinder" pos="-0.30  0.22 -0.40" size="0.03 0.40"
            rgba="0.50 0.50 0.50 1"/>
      <geom name="table_leg3" type="cylinder" pos=" 0.30 -0.22 -0.40" size="0.03 0.40"
            rgba="0.50 0.50 0.50 1"/>
      <geom name="table_leg4" type="cylinder" pos="-0.30 -0.22 -0.40" size="0.03 0.40"
            rgba="0.50 0.50 0.50 1"/>
    </body>

    <!-- ── Five-DoF arm ──
         robot_root is at world z = 0.810 (table top surface).
         All arm geoms inherit contype/conaffinity=1 → naturally collide with tabletop.
    -->
    <body name="robot_root" pos="0.52 0 0.810">
      <geom name="base_plate" type="cylinder" pos="0 0 0.02" size="0.065 0.02"
            rgba="0.35 0.35 0.38 1"
            contype="0" conaffinity="0"/>  <!-- base_plate is excluded from collision; table exclude above covers root body -->

      <!-- J1 base yaw about Z -->
      <body name="link_yaw" pos="0 0 0.035">
        <joint name="jnt1_base_z" type="hinge" axis="0 0 1"
               range="-2.793 2.793" damping="25" armature="0.06"/>
        <geom name="g_yaw" type="capsule" fromto="0 0 0 0 0 0.085" size="0.042"
              rgba="0.62 0.62 0.66 1"/>

        <!-- J2 shoulder pitch.
             axis="0 -1 0" → positive angle lifts the arm toward +Z (up).
             range: -0.524 rad (-30°) to 2.094 rad (+120°) — matches robot_kinematics.yaml -->
        <body name="shoulder_yaw" pos="0 0 0.088">
          <joint name="jnt2_shoulder_y" type="hinge" axis="0 -1 0"
                 range="-0.524 2.094"
                 damping="20" armature="0.04"
                 solreflimit="0.005 1" solimplimit="0 0.95 0.001 0.5 2"/>
          <geom name="upper_arm" type="capsule" fromto="0 0 0 0.22 0 0" size="0.035"
                rgba="0.15 0.45 0.85 1"/>
          <body name="elbow_hub" pos="0.22 0 0">
            <!-- J3 elbow: axis="0 -1 0".
                 range: -2.618 rad (-150°) to 0.175 rad (+10°) — matches robot_kinematics.yaml -->
            <joint name="jnt3_elbow_y" type="hinge" axis="0 -1 0"
                   range="-2.618 0.175"
                   damping="14" armature="0.03"
                   solreflimit="0.005 1" solimplimit="0 0.95 0.001 0.5 2"/>
            <geom name="forearm" type="capsule" fromto="0 0 0 0.22 0 0" size="0.03"
                  rgba="0.92 0.55 0.12 1"/>
            <body name="wrist_pitch_hub" pos="0.22 0 0">
              <!-- J4 wrist pitch: axis="0 -1 0". range ±120° = ±2.094 rad -->
              <joint name="jnt4_wrist_y" type="hinge" axis="0 -1 0"
                     range="-2.094 2.094" damping="12" armature="0.02"/>
              <geom name="wrist_geom" type="capsule" fromto="0 0 0 0.065 0 0" size="0.024"
                    rgba="0.82 0.82 0.82 1"/>
              <site name="eef_tip" pos="0.065 0 0" size="0.015" rgba="0 1 0 0"/>
              <body name="wrist_roll" pos="0.065 0 0">
                <!-- J5 gripper roll: X-axis rotation (forearm axial spin). ±180° = ±3.142 rad -->
                <joint name="jnt5_gripper_z" type="hinge" axis="1 0 0"
                       range="-3.142 3.142" damping="10" armature="0.02"/>
                <!-- Visual two-prong gripper; collision off so fingers don't fight physics -->
                <geom name="finger_l" type="box" pos="0.04  0.03 0" size="0.035 0.012 0.018"
                      rgba="0.12 0.12 0.12 1" contype="0" conaffinity="0"/>
                <geom name="finger_r" type="box" pos="0.04 -0.03 0" size="0.035 0.012 0.018"
                      rgba="0.12 0.12 0.12 1" contype="0" conaffinity="0"/>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Workspace safety box (transparent) — visual cue for allowed volume above table.
         Origin at robot_root (0.52, 0, 0.810 = table surface).
         Box centre offset: 0.25 m forward, 0.30 m above table (half-height 0.30 m).
         Full extent: 0.96 m deep × 0.80 m wide × 0.60 m tall above table. -->
    <body name="workspace_box" pos="0.52 0 0.810">
      <geom name="ws_volume" type="box" pos="0.25 0 0.30"
            size="0.48 0.40 0.30"
            rgba="0.2 0.7 1.0 0.04"
            contype="0" conaffinity="0"/>
    </body>

    <!-- Visual goal sphere — auto-synced to FK end-effector (eef_tip site) via
         _sync_goal_to_eef() in SimTeleopEnv.set_joint_degrees_deg.
         Shows where the arm tip actually is; zero visual mismatch with the arm. -->
    <body name="wrist_goal" mocap="true">
      <geom name="goal_ball" type="sphere" pos="0 0 0" size="0.022"
            rgba="1 0.45 0.0 0.90" contype="0" conaffinity="0"/>
    </body>

    <camera name="teleop_cam" mode="fixed" pos="1.95 1.95 1.42" euler="-28 -45 52"/>
  </worldbody>
</mujoco>
